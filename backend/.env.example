# ─────────────────────────────────────────────────────────────
# DocuFlow — backend environment
# Copy to `.env` and fill in real values: cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Database (async driver)
DATABASE_URL=postgresql+asyncpg://docuflow:secret@localhost:5432/docuflow

# Redis (cache + Celery broker/backend)
REDIS_URL=redis://localhost:6379/0

# Auth / JWT
SECRET_KEY=your-256-bit-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Secrets-at-rest encryption (connector configs, AI API keys).
# Leave blank to reuse SECRET_KEY. Generate a dedicated key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Object storage (MinIO / S3-compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=docuflow
MINIO_SECURE=false

# Platform
SUPER_ADMIN_EMAIL=admin@docuflow.com
FRONTEND_URL=http://localhost:5173

# App
DEBUG=true
